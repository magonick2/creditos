@model PlataformaCreditos.Models.SolicitudCredito

@{
    ViewData["Title"] = "Nueva Solicitud";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">Nueva Solicitud de Crédito</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="MontoSolicitado" class="form-label">Monto a Solicitar</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="MontoSolicitado" class="form-control" type="number" step="0.01" required />
                            </div>
                            <span asp-validation-for="MontoSolicitado" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success">Enviar Solicitud</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Volver al Listado</a>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-muted small">
                    Nota: El monto máximo es 10 veces sus ingresos mensuales registrados.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}